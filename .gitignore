__pycache__/
*.pyc
.venv/
venv/
.env
*.log
.DS_Store

# Local dev database is ignored to avoid committing a binary that conflicts on every
# run. The "git scraping" design (repo as durable state) is real, but the scheduled
# GitHub Action will be the *sole* writer that commits the production DB (step 6, via
# `git add -f`). Local runs stay out of version control.
data/*.db
