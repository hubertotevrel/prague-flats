# Copy to .env for local runs:  cp .env.example .env  (then fill in the values).
# .env is gitignored — never commit it. On GitHub, add these as repository secrets
# (Settings -> Secrets and variables -> Actions) with the same names.

# Mapy.com REST API key — https://developer.mapy.com (free Basic plan = 250k credits/mo).
MAPY_API_KEY=

# Telegram bot token from @BotFather, e.g. 123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_BOT_TOKEN=

# Your numeric chat id. After setting the token above and messaging your bot once, run:
#   python verify.py --telegram-chatid
TELEGRAM_CHAT_ID=

# Google Maps Routes API key — https://console.cloud.google.com (Routes API enabled,
# billing on). Used for door-to-door public-transport commute time. Free tier covers
# personal use; caching keeps calls low.
GOOGLE_MAPS_API_KEY=
